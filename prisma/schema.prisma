  sessions              Session[]          @relation("SessionsSalle")

  @@index([nom])
  @@index([statut])
  @@map("salles")
}

/// Créneaux horaires d'occupation d'une salle (granularité heure)
/// Permet de savoir qu'Atelier B est occupé 08h-12h par CAP et 14h-18h par Sertissage N1
model ReservationSalle {
  idReservation   Int        @id @default(autoincrement()) @map("id_reservation")
  idSalle         Int        @map("id_salle")
  idSession       Int?       @map("id_session")
  idEvenement     Int?       @map("id_evenement")
  dateDebut       DateTime   @map("date_debut") @db.Timestamptz(6)
  dateFin         DateTime   @map("date_fin") @db.Timestamptz(6)
  statut          String     @default("CONFIRME")
  motifAnnulation String?    @map("motif_annulation")
  notes           String?
  creeLe          DateTime   @default(now()) @map("cree_le") @db.Timestamptz(6)
  modifieLe       DateTime   @default(now()) @updatedAt @map("modifie_le") @db.Timestamptz(6)
  idFormateur     Int?       @map("id_formateur")
  matiere         String?
  typeFormation   String?    @default("COURTE") @map("type_formation")
  expiresAt       DateTime?  @map("expires_at") @db.Timestamptz(6)
  idCandidat      Int?       @map("id_candidat")
  token           String?    @unique
  idLot           String?    @map("id_lot")
  candidat        Candidat?  @relation("HoldsCandidat", fields: [idCandidat], references: [idCandidat])
  evenement       Evenement? @relation(fields: [idEvenement], references: [idEvenement])
  formateur       Formateur? @relation("ReservationsFormateur", fields: [idFormateur], references: [idFormateur])
  salle           Salle      @relation(fields: [idSalle], references: [idSalle])
  session         Session?   @relation(fields: [idSession], references: [idSession])

  @@index([idSalle, dateDebut, dateFin])
  @@index([idSession])
  @@index([idEvenement])
  @@index([idFormateur])
  @@index([matiere])
  @@index([typeFormation])
  @@index([token])
  @@index([idCandidat, statut])
  @@index([idLot])
  @@map("reservations_salles")
}

/// Événements du planning (portes ouvertes, stages, réunions, etc.)
