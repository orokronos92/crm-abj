model Salle {
  idSalle               Int                @id @default(autoincrement()) @map("id_salle")
  nom                   String             @unique
  code                  String?            @unique
  capaciteMax           Int                @map("capacite_max")
  surfaceM2             Int?               @map("surface_m2")
  etage                 Int?
  equipements           String[]           @default([])
  formationsCompatibles String[]           @default([]) @map("formations_compatibles")
  disponibleWeekend     Boolean            @default(false) @map("disponible_weekend")
  disponibleSoir        Boolean            @default(false) @map("disponible_soir")
  statut                String             @default("ACTIVE")
  motifIndisponibilite  String?            @map("motif_indisponibilite")
  dateDebutIndispo      DateTime?          @map("date_debut_indispo") @db.Date
  dateFinIndispo        DateTime?          @map("date_fin_indispo") @db.Date
