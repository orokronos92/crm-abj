  idFormateur  Int       @map("id_formateur")
  type         String
  nomActivite  String    @map("nom_activite")
  organisme    String?
  dateActivite DateTime  @map("date_activite") @db.Date
  duree        Int?
  uniteDuree   String    @default("heures") @map("unite_duree")
  creeLe       DateTime  @default(now()) @map("cree_le") @db.Timestamptz(6)
  modifieLe    DateTime  @default(now()) @updatedAt @map("modifie_le") @db.Timestamptz(6)
  formateur    Formateur @relation(fields: [idFormateur], references: [idFormateur], onDelete: Cascade)

  @@index([idFormateur])
  @@index([type])
  @@index([dateActivite])
  @@map("formateur_veille_professionnelle")
}
