model Evenement {
  idEvenement             Int                @id @default(autoincrement()) @map("id_evenement")
  type                    String
  titre                   String
  description             String?
  date                    DateTime           @db.Date
  heureDebut              String             @map("heure_debut")
  heureFin                String             @map("heure_fin")
  salle                   String
  nombreParticipants      Int                @map("nombre_participants")
  participantsInscrits    Int?               @default(0) @map("participants_inscrits")
  statut                  String             @default("PLANIFIE")
  motifAnnulation         String?            @map("motif_annulation")
  creePar                 Int?               @map("cree_par")
  modifiePar              Int?               @map("modifie_par")
  annulePar               Int?               @map("annule_par")
  creeLe                  DateTime           @default(now()) @map("cree_le") @db.Timestamptz(6)
  modifieLe               DateTime           @default(now()) @updatedAt @map("modifie_le") @db.Timestamptz(6)
